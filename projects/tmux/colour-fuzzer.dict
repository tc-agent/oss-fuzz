"rgb:00/ff/00"
"rgb:00/00/ff"
"rgb:ffff/0000/0000"

# CMYK (handled by colour_parseX11)
"cmyk:0/0/0/0"
"cmyk:1/0/0/0"
"cmy:0.5/0.5/0.5"

# Numeric (handled by colour_fromstring for 0-7 and 90-97)
"0"
"7"
"90"
"97"

